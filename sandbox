#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CWD="$(pwd)"

# Derive a container-name-safe slug from a directory path
_dir_slug() {
    local dir="$1"
    local name hash
    name=$(basename "$dir" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed -E 's/^-+|-+$//g')
    hash=$(printf '%s' "$dir" | md5sum | cut -c1-6)
    echo "claude-${name:-project}-${hash}"
}

export IMAGE_NAME="claude-sandbox"
export PROJECT_PATH="${PROJECT_PATH:-$CWD}"
export SANDBOX_NAME="${SANDBOX_NAME:-$(_dir_slug "$PROJECT_PATH")}"
export COMPOSE_PROJECT_NAME="$SANDBOX_NAME"

cd "$SCRIPT_DIR"

_usage() {
    cat <<EOF
Usage: $(basename "$0") [COMMAND | PROMPT]

Commands:
  build       Rebuild the sandbox image
  status      Show container status and resource usage
  shell       Open a bash shell in the sandbox
  exec        Run a command inside the sandbox (e.g. ./sandbox exec ls -la)
  restart     Restart the sandbox container
  stop        Stop the sandbox container
  clean       Stop and remove this directory's container
  purge       Stop and remove this directory's container and the shared image
  logs        Tail container logs
  help        Show this message

If no command is given:
  - With a TTY:            starts an interactive Claude session
  - With a prompt argument: runs Claude non-interactively
  - With piped stdin:       passes stdin as the prompt

Each directory gets its own container, named from a slug of PROJECT_PATH.

Environment:
  SANDBOX_NAME      Override container name (default: derived from PROJECT_PATH)
  PROJECT_PATH      Project directory to mount (default: current directory)
  ANTHROPIC_API_KEY API key as an alternative to OAuth credentials

Examples:
  ./sandbox                              # uses current directory
  ./sandbox "refactor the auth module"
  echo "what does main.go do?" | ./sandbox
  ./sandbox shell
  ./sandbox exec python3 -c "print('hello')"
  PROJECT_PATH=~/proj-b ./sandbox        # explicit project directory
EOF
}

_is_running() {
    docker ps --filter "name=^${SANDBOX_NAME}$" --format '{{.Names}}' 2>/dev/null \
        | grep -q "^${SANDBOX_NAME}$"
}

_ensure_built() {
    local image_id
    image_id=$(docker images -q "${IMAGE_NAME}" 2>/dev/null || true)
    if [[ -z "$image_id" ]]; then
        echo "[sandbox] image not found, building..." >&2
        docker compose build
    fi
}

_ensure_running() {
    _ensure_built
    if ! _is_running; then
        echo "[sandbox] starting ${SANDBOX_NAME}..." >&2
        docker compose up -d
    fi
}

# Build docker exec env args for ANTHROPIC_API_KEY passthrough
_env_args() {
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        echo "-e" "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY"
    fi
}

# Re-run the entrypoint credential merge so that any tokens refreshed on the
# host since the container started are picked up before invoking claude.
_refresh_credentials() {
    docker exec "$SANDBOX_NAME" /home/sandbox/entrypoint.sh true 2>/dev/null || true
}

case "${1:-}" in
    help|--help|-h)
        _usage; exit 0 ;;
    build)
        docker compose build ;;
    status)
        if _is_running; then
            docker stats --no-stream "$SANDBOX_NAME"
        else
            echo "[sandbox] ${SANDBOX_NAME} is not running"
        fi ;;
    stop)
        docker compose stop ;;
    restart)
        docker compose restart ;;
    clean)
        docker compose down ;;
    purge)
        docker compose down --rmi local ;;
    logs)
        docker compose logs -f ;;
    shell)
        _ensure_running
        docker exec -it "$SANDBOX_NAME" bash ;;
    exec)
        shift
        _ensure_running
        docker exec -it $(_env_args) "$SANDBOX_NAME" "$@" ;;
    *)
        _ensure_running
        _refresh_credentials
        if [[ $# -gt 0 ]]; then
            # Prompt passed as argument(s)
            docker exec -i $(_env_args) "$SANDBOX_NAME" claude -p "$*"
        elif [[ ! -t 0 ]]; then
            # Piped stdin
            docker exec -i $(_env_args) "$SANDBOX_NAME" claude -p "$(cat)"
        else
            # Interactive
            docker exec -it $(_env_args) "$SANDBOX_NAME" claude --dangerously-skip-permissions --continue || \
            docker exec -it $(_env_args) "$SANDBOX_NAME" claude --dangerously-skip-permissions
        fi ;;
esac
